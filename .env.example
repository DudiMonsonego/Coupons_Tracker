# Supabase (required for build + runtime — set in Vercel → Settings → Environment Variables)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only (onboarding/admin; never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Public site URL (production: https://your-app.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: GPT-4o-mini vision for coupon image OCR on import
OPENAI_API_KEY=
